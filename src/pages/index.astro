---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KeyCraft Custom | Premium Personalized Keychains">
	<!-- Navigation -->
	<nav class="bg-surface/90 backdrop-blur-md sticky top-0 z-50 border-b border-outline-variant/30 shadow-sm w-full">
		<div class="flex justify-between items-center px-margin-mobile md:px-gutter max-w-container-max mx-auto h-20 w-full">
			<span class="font-display-lg text-headline-md font-bold text-primary">KeyCraft Custom</span>
			
			<!-- Mobile Menu Toggle -->
			<button aria-label="Toggle Menu" class="md:hidden text-on-surface p-2" id="mobile-menu-btn">
				<span class="material-symbols-outlined">menu</span>
			</button>

			<!-- Desktop Links -->
			<div class="hidden md:flex items-center gap-8">
				<a class="text-primary font-bold border-b-2 border-primary pb-1 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#categories">Categories</a>
				<a class="text-on-surface-variant font-medium hover:text-primary transition-colors font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#why-choose-us">Why Choose Us</a>
				<a class="text-on-surface-variant font-medium hover:text-primary transition-colors font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#gallery">Gallery</a>
				<a class="text-on-surface-variant font-medium hover:text-primary transition-colors font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#process">Process</a>
				<a class="text-on-surface-variant font-medium hover:text-primary transition-colors font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#faq">FAQ</a>
				<button class="bg-primary-container text-on-primary px-6 py-2 rounded-lg font-bold hover:scale-105 transition-transform duration-200">WhatsApp Order</button>
			</div>
		</div>
		
		<!-- Mobile Menu Overlay -->
		<div class="hidden md:hidden absolute top-20 left-0 w-full bg-surface border-b border-outline-variant/30 px-margin-mobile py-stack-md flex flex-col gap-4 shadow-xl" id="mobile-menu">
			<a class="text-primary font-bold py-2 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#categories">Categories</a>
			<a class="text-on-surface-variant font-medium py-2 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#why-choose-us">Why Choose Us</a>
			<a class="text-on-surface-variant font-medium py-2 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#gallery">Gallery</a>
			<a class="text-on-surface-variant font-medium py-2 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#process">Process</a>
			<a class="text-on-surface-variant font-medium py-2 font-label-caps text-[12px] tracking-[0.1em] uppercase" href="#faq">FAQ</a>
			<button class="bg-primary-container text-on-primary w-full py-4 rounded-lg font-bold mt-2">WhatsApp Order</button>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<!-- Mobile Version -->
		<section class="md:hidden px-margin-mobile pt-stack-md pb-stack-lg flex flex-col items-center text-center max-w-container-max mx-auto overflow-hidden">
			<div class="max-w-xl mb-stack-md">
				<h1 class="font-display-lg-mobile text-[32px] font-bold text-on-surface mb-stack-sm tracking-tight leading-[1.2]">
					Crafting <span class="text-primary">Precision</span> In Every Pocket
				</h1>
				<p class="font-body-md text-[16px] text-on-surface-variant mb-stack-md leading-relaxed">
					Premium bespoke keychains for makers, designers, and enthusiasts. Elevate your everyday carry with industrial-grade materials and custom artistry.
				</p>
				<div class="flex flex-col gap-4 w-full">
					<button class="bg-primary-container text-on-primary font-bold py-4 rounded-lg hover:scale-105 active:scale-95 transition-all shadow-lg">Start Customizing</button>
					<button class="border-2 border-secondary text-secondary font-bold py-4 rounded-lg hover:bg-secondary hover:text-white transition-all">View Gallery</button>
				</div>
			</div>
			<div class="relative w-full aspect-[3/4] rounded-xl overflow-hidden mt-stack-md shadow-[0_4px_20px_rgba(95,94,94,0.1)]">
				<img class="w-full h-full object-cover" alt="Premium custom wooden keychain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCoQaOmW4KnE-cyNB0WIU2i7yb6Gf2b5V93Ygr9aHYVF6rtC1G9NbnPrdGA87Pj9Covrk9gkPHlCF2o0sXr0HDk1jOXBnHAVdhgLlKMtj9WPp0cyjmpE3tXUfue13t2LEE5g9nm2NjE2mFyXDBoiFcqra-FpObbZoj5nNjToYQedXFagMM3JQJv1XeoSpbjbwjrkdTJAqmoJ-yMEDL2jJoNZQnEhWqFYTPnmkydEz_ajtPt5sqBEPNJ0qgEwG2wssz29eM2GqQ9Lxc"/>
			</div>
		</section>

		<!-- Desktop Version -->
		<section class="hidden md:flex relative h-[870px] items-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<img class="w-full h-full object-cover" alt="Custom handcrafted keychains" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBnjoRrRlkLKq3CrnWR2BMVhxPR1a9VopfN22bGsYBTddL1__kk0_ATsg6qdayaY6Yr8khifcdVht-1AZPrbirF_QQopTNanrr5RK6aHWC-DeeOzUweGJae9nmX7l8s5325R62TTccIjD10Fj7P2tLGQvnEzpS5G0jPlyCfoxVJICQLGDMQknkkGSPk42YN0m_buXbIDNxsP5wWQ3yv0pIdAwws-fCShDqlbzXzCgjEFkTpnkFq3E76KwnblLZKyslw_wk_33jKJoE"/>
				<div class="absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/20 to-transparent"></div>
			</div>
			<div class="container max-w-container-max mx-auto px-gutter relative z-10">
				<div class="max-w-2xl text-white">
					<h1 class="font-display-lg text-[48px] leading-[1.1] font-bold mb-stack-sm drop-shadow-lg">
						Custom Keychains for Every Occasion
