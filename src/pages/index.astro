	<script>
		// Mobile Menu Logic
		const btn = document.getElementById('mobile-menu-btn');
		const menu = document.getElementById('mobile-menu');
		let isOpen = false;
		btn.addEventListener('click', () => {
			isOpen = !isOpen;
			menu.classList.toggle('hidden');
			btn.innerHTML = isOpen ? '<span class="material-symbols-outlined">close</span>' : '<span class="material-symbols-outlined">menu</span>';
		});

		// Accordion Logic (Global)
		// @ts-ignore
		window.toggleAccordion = function(element) {
			const content = element.nextElementSibling;
			const icon = element.querySelector('.material-symbols-outlined');
			const parent = element.parentElement;
			if (content.style.maxHeight) {
				content.style.maxHeight = null;
				icon.style.transform = 'rotate(0deg)';
				parent.classList.remove('border-primary');
			} else {
				content.style.maxHeight = content.scrollHeight + "px";
				icon.style.transform = 'rotate(180deg)';
				parent.classList.add('border-primary');
			}
		}
	</script>
