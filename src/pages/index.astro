---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KeyCraft Custom | Premium Personalized Keychains">
	<div id="mobile-view">
		<!-- SELURUH KODE MOBILE DISINI -->
		<nav class="bg-surface/90 backdrop-blur-md sticky top-0 z-50 border-b border-outline-variant/30 h-20 flex items-center px-4 justify-between">
			<span class="font-display-lg text-headline-md font-bold text-primary">KeyCraft Custom</span>
			<span class="material-symbols-outlined">menu</span>
		</nav>
		<section class="px-6 py-10 text-center">
			<h1 class="text-display-lg-mobile font-bold text-on-surface leading-tight">
				Crafting <span class="text-primary">Precision</span> In Every Pocket
			</h1>
			<p class="text-body-md text-on-surface-variant mt-4">Premium bespoke keychains for makers and enthusiasts.</p>
			<div class="mt-8 flex flex-col gap-4">
				<button class="bg-primary-container text-on-primary py-4 rounded-lg font-bold">Start Customizing</button>
			</div>
			<img class="mt-10 rounded-xl w-full shadow-lg" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCoQaOmW4KnE-cyNB0WIU2i7yb6Gf2b5V93Ygr9aHYVF6rtC1G9NbnPrdGA87Pj9Covrk9gkPHlCF2o0sXr0HDk1jOXBnHAVdhgLlKMtj9WPp0cyjmpE3tXUfue13t2LEE5g9nm2NjE2mFyXDBoiFcqra-FpObbZoj5nNjToYQedXFagMM3JQJv1XeoSpbjbwjrkdTJAqmoJ-yMEDL2jJoNZQnEhWqFYTPnmkydEz_ajtPt5sqBEPNJ0qgEwG2wssz29eM2GqQ9Lxc"/>
		</section>
	</div>

	<div id="desktop-view">
		<!-- SELURUH KODE DESKTOP DISINI -->
		<header class="bg-surface/90 backdrop-blur-md border-b border-outline-variant/30 h-20 flex items-center px-gutter justify-between sticky top-0 z-50">
			<div class="text-display-lg text-headline-md font-bold text-primary">KeyCraft Custom</div>
			<div class="flex gap-8 items-center">
				<a href="#" class="text-label-caps font-bold">Categories</a>
				<a href="#" class="text-label-caps font-bold">Why Choose Us</a>
				<a href="#" class="text-label-caps font-bold">Gallery</a>
				<button class="bg-primary-container text-on-primary px-6 py-2 rounded-full font-bold">WhatsApp Order</button>
			</div>
		</header>
		<section class="relative h-[800px] flex items-center px-gutter overflow-hidden">
			<img class="absolute inset-0 w-full h-full object-cover -z-10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBnjoRrRlkLKq3CrnWR2BMVhxPR1a9VopfN22bGsYBTddL1__kk0_ATsg6qdayaY6Yr8khifcdVht-1AZPrbirF_QQopTNanrr5RK6aHWC-DeeOzUweGJae9nmX7l8s5325R62TTccIjD10Fj7P2tLGQvnEzpS5G0jPlyCfoxVJICQLGDMQknkkGSPk42YN0m_buXbIDNxsP5wWQ3yv0pIdAwws-fCShDqlbzXzCgjEFkTpnkFq3E76KwnblLZKyslw_wk_33jKJoE"/>
			<div class="absolute inset-0 bg-gradient-to-r from-primary/60 to-transparent -z-10"></div>
			<div class="max-w-2xl text-white">
				<h1 class="text-display-lg font-bold drop-shadow-xl">Custom Keychains for Every Occasion</h1>
				<p class="text-body-lg mt-6 opacity-90">Premium, maker-quality craftsmanship for personal expression, gifts, and brand merchandise.</p>
				<div class="mt-10 flex gap-4">
					<button class="bg-primary-container text-on-primary-container px-8 py-4 rounded-xl font-bold">Order via WhatsApp</button>
				</div>
			</div>
		</section>
	</div>

	<style>
		/* HARDCORE HIDDEN LOGIC */
		@media (min-width: 768px) {
			#mobile-view { display: none !important; }
			#desktop-view { display: block !important; }
		}
		@media (max-width: 767px) {
			#mobile-view { display: block !important; }
			#desktop-view { display: none !important; }
		}
	</style>
</Layout>
