				<h2 class="font-headline-md text-headline-md text-on-surface mb-stack-lg text-center">The Making Process</h2>
				<div class="relative pl-8 border-l-2 border-outline-variant/30 flex flex-col gap-stack-lg">
					<div class="relative">
						<div class="absolute -left-[41px] top-0 w-4 h-4 bg-primary rounded-full border-4 border-white shadow-sm"></div>
